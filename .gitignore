# Generated by Cargo
/target/
/crates/slicer-wasm-host/test-guests/target/
/crates/slicer-wasm-host/test-guests/*/target/
/modules/core-modules/*/wit-guest/target/
# Defensive: catches any nested target/ created by a worker that ran cargo with the wrong cwd
# (added in packet 89 closure after a stray resources/target/ was discovered).
**/target/

# Compiled WASM module/component artifacts
*.wasm

# Backup files
**/*.rs.bk

# Windows debugging information
*.pdb

# OrcaSlicer src and documentation
/OrcaSlicerDocumented/

# Other files and directories to ignore
.worktrees/
.env
tmp/

# Local settings and worktrees for LLM development
.claude/settings.local.json
.claude/worktrees/
