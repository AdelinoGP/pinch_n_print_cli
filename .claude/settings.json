{
  "rust": {
    "command": "rust-analyzer",
    "args": [],
    "extensionToLanguage": {
      ".rs": "rust"
    },
    "transport": "stdio"
  },
  "permissions": {
    "deny": [
      "Bash(git push)",
      "Bash(git push *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "rustfmt \"$CLAUDE_TOOL_INPUT_FILE_PATH\""
          }
        ]
      },
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "timeout": 1800,
            "statusMessage": "EnterWorktree: building guest wasms (full cold compile)...",
            "command": "cargo xtask build-guests"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cargo fmt && cargo clippy --all-targets --message-format=short -- -D warnings",
            "timeout": 600
          }
        ]
      }
    ],
    "TaskCompleted": []
  }
}