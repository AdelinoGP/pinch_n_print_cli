{
  "rust": {
    "command": "rust-analyzer",
    "args": [],
    "extensionToLanguage": {
      ".rs": "rust"
    },
    "transport": "stdio"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_TOOL_INPUT_FILE_PATH\" == *.rs ]]; then rustfmt \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cargo fmt && cargo clippy --all-targets --message-format=short -- -D warnings",
            "timeout": 600
          }
        ]
      }
    ],
    "TaskCompleted": [
        {
          "matcher": "",
          "hooks": [
            {
              "type": "command",
              "timeout": 30,
              "command": "bash -c 'cd \"$CLAUDE_PROJECT_DIR\" && { ./modules/core-modules/build-core-modules.sh --check && ./test-guests/build-test-guests.sh --check; } 1>&2 || exit 2'"
            }
          ]
        }
      ]
  }
}